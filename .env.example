# ============================================================================
# Polymarket CLOB Credentials (Required for Live Trading Only)
# ============================================================================

# Your Polymarket API key (create at https://polymarket.com/settings/api)
POLY_API_KEY=your_api_key_here

# API secret (keep SECRET — do not commit)
POLY_API_SECRET=your_api_secret_here

# API passphrase (keep SECRET — do not commit)
POLY_API_PASSPHRASE=your_passphrase_here

# Optional: Signer private key (if using explicit key derivation)
# Leave blank to use default signer flow
POLY_SIGNER_KEY=

# ============================================================================
# Discord Webhooks (Optional — for alerts)
# ============================================================================

# Primary webhook for all bot notifications
DISCORD_WEBHOOK_URL=

# Dedicated webhook for Kakashi v2 (overrides primary if set)
KAKASHI_V2_WEBHOOK_URL=

# ============================================================================
# Kalshi API (Optional — if using Kalshi integration)
# ============================================================================

KALSHI_USERNAME=
KALSHI_PASSWORD=

# ============================================================================
# AWS Credentials (Optional — if using S3 for logs/data)
# ============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================================
# Logging & Debug
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Paper trading mode (set to False to enable live trading ONLY after verification)
LIVE_TRADING=False

# ============================================================================
# Environment
# ============================================================================

# Environment: local, dev, prod
ENVIRONMENT=local
